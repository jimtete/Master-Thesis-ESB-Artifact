# Build results
**/[Bb]in/
**/[Oo]bj/
**/[Dd]ebug*/
**/[Rr]elease*/
**/[Xx]64/
**/[Xx]86/
**/[Aa]ny [Cc][Pp][Uu]/
**/[Ll]og/
**/[Oo]ut/

# Publish / artifacts
**/publish/
**/app.publish/
**/*.publishproj
**/*.nupkg
**/*.snupkg
**/*.symbols.nupkg
**/artifacts/

# Test results
**/[Tt]est[Rr]esult*/
**/*.trx
**/*.coverage
**/*.coveragexml

# VS cache / user settings
.vs/
**/*.suo
**/*.user
**/*.userosscache
**/*.sln.docstates
**/*.rsuser

# JetBrains Rider / IntelliJ
.idea/
**/*.sln.iml
**/*.DotSettings.user
**/_ReSharper*/
**/*.[Rr]e[Ss]harper
**/*.resharper.user
**/.cache/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# NuGet (legacy)
packages/
**/packages/*

# Node (if you ever add a UI project)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment / secrets (safe defaults)
.env
.env.*
!.env.example
**/*secrets*.json
**/appsettings.*.local.json
**/appsettings.*.Development.local.json

# Logs / temp
*.log
*.tmp
*.temp

