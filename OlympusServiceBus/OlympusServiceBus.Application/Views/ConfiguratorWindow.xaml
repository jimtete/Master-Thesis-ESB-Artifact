<Window x:Class="OlympusServiceBusApplication.Views.ConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:OlympusServiceBusApplication.Models"
        mc:Ignorable="d"
        Title="Olympus Service Bus Configurator"
        Height="800"
        Width="1200"
        MinHeight="800"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type models:FileExplorerNode}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <TextBlock Text="Contracts Directory"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,6,0,0"
                           Text="{Binding ContractsDirectoryPath}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Contracts Explorer">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding NewDirectoryName, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="30"
                                 VerticalContentAlignment="Center" />

                        <Button Grid.Column="2"
                                Content="Create Folder"
                                MinHeight="30"
                                Command="{Binding CreateDirectoryCommand}" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding NewContractName, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="30"
                                 VerticalContentAlignment="Center" />

                        <Button Grid.Column="2"
                                Content="Create Contract"
                                MinHeight="30"
                                Command="{Binding CreateContractCommand}" />
                    </Grid>

                    <Button Grid.Row="4"
                            Content="Refresh"
                            Width="140"
                            HorizontalAlignment="Left"
                            MinHeight="30"
                            Command="{Binding RefreshCommand}" />

                    <Border Grid.Row="6"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6">
                        <TreeView x:Name="ContractsTreeView"
                                  ItemsSource="{Binding RootNode.Children}" />
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Details">
                <Grid Margin="8">
                    <TextBlock Text="Details/editor area will come later." />
                </Grid>
            </GroupBox>
        </Grid>

        <Border Grid.Row="4"
                Padding="8"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>
