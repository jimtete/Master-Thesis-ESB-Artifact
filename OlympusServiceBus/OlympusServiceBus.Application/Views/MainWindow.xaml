<Window x:Class="OlympusServiceBusApplication.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Olympus Service Bus Setup"
        Height="250"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Select Contracts Root Directory"
                   FontSize="18"
                   FontWeight="SemiBold" />

        <TextBlock Grid.Row="2"
                   Text="Choose the root folder where the application will manage its Contracts workspace."
                   TextWrapping="Wrap" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding ContractsRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="32"
                     VerticalContentAlignment="Center" />

            <Button Grid.Column="2"
                    Content="Browse..."
                    MinHeight="32"
                    Command="{Binding BrowseContractsRootDirectoryCommand}" />
        </Grid>
    </Grid>
</Window>