{
  "ApiToApi": {
    "Source": { "Endpoint": "https://localhost:7278/get-random-guest-registration-full-name", "Method": "GET" },
    "Sink": { "Endpoint": "http://localhost:5050/s2s-api/v1/Meetings", "Method": "POST" },
    "Mappings": [
      {
        "TransformationType": "Split",
        "SourceFieldName": "fullName",
        "SinkFields": ["firstName", "lastName"],
        "Separator": " "
      },
      { "TransformationType": "Direct", "SourceFieldName": "email", "SinkFieldName": "emailAddress" },
      { "TransformationType": "Direct", "SourceFieldName": "meetingDateTime", "SinkFieldName": "meetingTime" },
      { "TransformationType": "Direct", "SourceFieldName": "duration", "SinkFieldName": "meetingDurationInHours" },
      { "TransformationType": "Direct", "SourceFieldName": "registeredBy", "SinkFieldName": "registeredBy" }
    ]
  }
}
