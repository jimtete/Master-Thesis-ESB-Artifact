{
  "PortToApi": {
    "Enabled": true,
    "Listener": { "Path": "/ingress/meeting", "Method": "POST" },
    "Request": {
      "Fields": [
        { "FieldName": "fullName", "Type": "String", "Required": true },
        { "FieldName": "email", "Type": "String", "Required": true },
        { "FieldName": "meetingDateTime", "Type": "String", "Required": true },
        { "FieldName": "duration", "Type": "Number", "Required": true },
        { "FieldName": "registeredBy", "Type": "String", "Required": true }
      ]
    },
    "Sink": { "Endpoint": "http://localhost:5050/s2s-api/v1/Meetings", "Method": "POST" },
    "Mappings": [
      { "TransformationType": "Split", "SourceFieldName": "fullName", "SinkFields": ["firstName","lastName"], "Separator": " " },
      { "TransformationType": "Direct", "SourceFieldName": "email", "SinkFieldName": "emailAddress" },
      { "TransformationType": "Direct", "SourceFieldName": "meetingDateTime", "SinkFieldName": "meetingTime" },
      { "TransformationType": "Direct", "SourceFieldName": "duration", "SinkFieldName": "meetingDurationInHours" },
      { "TransformationType": "Direct", "SourceFieldName": "registeredBy", "SinkFieldName": "registeredBy" }
    ]
  }
}
